{
  "name": "@caffeine/template-app",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm -r --if-present run check",
    "fix": "pnpm -r --if-present run fix"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  },
  "pnpm": {
    "overrides": {
      "csstype": "3.1.3",
      "@types/react": "19.1.17",
      "@types/react-dom": "19.1.11",
      "react": "19.1.5",
      "react-dom": "19.1.5"
    }
  }
}
